generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admin {
  id           String    @id
  email        String    @unique(map: "Admin_email_key")
  password     String
  name         String?
  role         String    @default("ADMIN")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  isVerified   Boolean   @default(false)
  otp          String?
  otpExpiresAt DateTime?
}

model bulkorder {
  id           Int     @id @default(autoincrement())
  orderId      Int     @unique(map: "BulkOrder_orderId_key")
  eventName    String?
  organization String?
  quantity     Int?
  notes        String? @db.Text
  orders       orders  @relation(fields: [orderId], references: [id], map: "BulkOrder_orderId_fkey")
}

model bulkpricing {
  id            Int      @id @default(autoincrement())
  categoryLabel String   @unique(map: "BulkPricing_categoryLabel_key")
  basePrice     Decimal
  bulkPrice     Decimal
  bulkThreshold Int      @default(100)
  minOrderQty   Int      @default(50)
  updatedAt     DateTime
}

model cake {
  id           Int           @id @default(autoincrement())
  name         String
  description  String?       @db.Text
  availability Boolean       @default(true)
  ingredients  String?       @db.Text
  imageUrl     String?
  categoryId   Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  cakecategory cakecategory  @relation(fields: [categoryId], references: [id], map: "Cake_categoryId_fkey")
  cakevariant  cakevariant[]

  @@index([categoryId], map: "Cake_categoryId_fkey")
}

model cakecategory {
  id        Int     @id @default(autoincrement())
  name      String  @unique(map: "CakeCategory_name_key")
  basePrice Decimal @default(0.000000000000000000000000000000)
  imageUrl  String?
  cake      cake[]
}

model cakeflavor {
  id          Int           @id @default(autoincrement())
  label       String        @unique(map: "CakeFlavor_label_key")
  price       Decimal       @default(0.000000000000000000000000000000)
  cakevariant cakevariant[]
}

model cakeshape {
  id          Int           @id @default(autoincrement())
  label       String        @unique(map: "CakeShape_label_key")
  price       Decimal       @default(0.000000000000000000000000000000)
  cakevariant cakevariant[]
}

model cakesize {
  id          Int           @id @default(autoincrement())
  label       String        @unique(map: "CakeSize_label_key")
  price       Decimal       @default(0.000000000000000000000000000000)
  cakevariant cakevariant[]
}

model cakevariant {
  id          Int         @id @default(autoincrement())
  price       Decimal
  cakeId      Int
  sizeId      Int
  shapeId     Int
  flavorId    Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  isAvailable Boolean     @default(true)
  cake        cake        @relation(fields: [cakeId], references: [id], onDelete: Cascade, map: "CakeVariant_cakeId_fkey")
  cakeflavor  cakeflavor  @relation(fields: [flavorId], references: [id], map: "CakeVariant_flavorId_fkey")
  cakeshape   cakeshape   @relation(fields: [shapeId], references: [id], map: "CakeVariant_shapeId_fkey")
  cakesize    cakesize    @relation(fields: [sizeId], references: [id], map: "CakeVariant_sizeId_fkey")
  cartitem    cartitem[]
  orderitem   orderitem[]

  @@unique([cakeId, sizeId, flavorId, shapeId], map: "CakeVariant_cakeId_sizeId_flavorId_shapeId_key")
  @@index([flavorId], map: "CakeVariant_flavorId_fkey")
  @@index([shapeId], map: "CakeVariant_shapeId_fkey")
  @@index([sizeId], map: "CakeVariant_sizeId_fkey")
}

model cart {
  id         Int        @id @default(autoincrement())
  customerId String
  status     String     @default("ACTIVE")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime
  customer   customer   @relation(fields: [customerId], references: [id], map: "Cart_customerId_fkey")
  cartitem   cartitem[]

  @@index([customerId], map: "Cart_customerId_fkey")
}

model cartitem {
  id          Int         @id @default(autoincrement())
  cartId      Int
  variantId   Int
  quantity    Int
  cart        cart        @relation(fields: [cartId], references: [id], map: "CartItem_cartId_fkey")
  cakevariant cakevariant @relation(fields: [variantId], references: [id], map: "CartItem_variantId_fkey")

  @@index([cartId], map: "CartItem_cartId_fkey")
  @@index([variantId], map: "CartItem_variantId_fkey")
}

model cashbook {
  id             Int           @id @default(autoincrement())
  date           DateTime      @db.Date
  openingBalance Decimal?      @db.Decimal(10, 2)
  closingBalance Decimal?      @db.Decimal(10, 2)
  totalIncome    Decimal       @default(0.00) @db.Decimal(10, 2)
  totalExpense   Decimal       @default(0.00) @db.Decimal(10, 2)
  transaction    transaction[]
}

model customer {
  id                 String               @id
  displayId          String               @unique(map: "Customer_displayId_key")
  name               String
  email              String               @unique(map: "Customer_email_key")
  password           String
  phone              String?
  address            String?
  loyaltyPoints      Int                  @default(0)
  isActive           Boolean              @default(true)
  isVerified         Boolean              @default(false)
  otp                String?
  otpExpiresAt       DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  cart               cart[]
  feedback           feedback[]
  loyaltytransaction loyaltytransaction[]
  notification       notification[]
  orders             orders[]
}

model customorder {
  id                  Int      @id @default(autoincrement())
  orderId             Int      @unique(map: "CustomOrder_orderId_key")
  sizeId              Int?
  flavorId            Int?
  shapeId             Int?
  quantity            Int?
  specialInstructions String?  @db.Text
  calculatedPrice     Decimal?
  orders              orders   @relation(fields: [orderId], references: [id], map: "CustomOrder_orderId_fkey")
}

model delivery {
  id                      Int      @id @default(autoincrement())
  orderId                 Int      @unique(map: "Delivery_orderId_key")
  recipientName           String?
  phoneNumber             String?
  email                   String?
  address                 String   @db.Text
  deliveryMethod          String?
  distanceKm              Decimal? @db.Decimal(6, 2)
  deliveryFee             Decimal? @default(0.000000000000000000000000000000)
  approximateDeliveryTime String?
  orders                  orders   @relation(fields: [orderId], references: [id], map: "Delivery_orderId_fkey")
}

model emaillog {
  id      Int      @id @default(autoincrement())
  orderId Int?
  email   String
  status  String
  error   String?  @db.Text
  sentAt  DateTime @default(now())
}

model event {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  type        String
  category    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
}

model feedback {
  id         Int       @id @default(autoincrement())
  rating     Int
  title      String?
  comment    String    @db.Text
  status     String    @default("PENDING")
  customerId String
  orderId    Int       @unique(map: "Feedback_orderId_key")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  reply      String?   @db.Text
  replyAt    DateTime?
  customer   customer  @relation(fields: [customerId], references: [id], map: "Feedback_customerId_fkey")
  orders     orders    @relation(fields: [orderId], references: [id], map: "Feedback_orderId_fkey")

  @@index([customerId], map: "Feedback_customerId_fkey")
}

model formfield {
  id           Int      @id @default(autoincrement())
  formType     String
  fieldId      String
  label        String
  fieldType    String
  required     Boolean  @default(false)
  active       Boolean  @default(true)
  displayOrder Int      @default(99)
  section      String   @default("basic_details")
  options      String?  @db.Text
  config       String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@unique([formType, fieldId], map: "FormField_formType_fieldId_key")
  @@index([formType, active], map: "FormField_formType_active_idx")
}

model invoice {
  id            Int      @id @default(autoincrement())
  orderId       Int      @unique(map: "Invoice_orderId_key")
  invoiceNumber String?
  issuedAt      DateTime @default(now())
  orders        orders   @relation(fields: [orderId], references: [id], map: "Invoice_orderId_fkey")
}

model itemrating {
  id          Int       @id @default(autoincrement())
  orderItemId Int       @unique(map: "ItemRating_orderItemId_key")
  stars       Int
  createdAt   DateTime  @default(now())
  orderitem   orderitem @relation(fields: [orderItemId], references: [id], map: "ItemRating_orderItemId_fkey")
}

model loyaltytransaction {
  id             Int      @id @default(autoincrement())
  customerId     String
  orderId        Int?
  pointsEarned   Int      @default(0)
  pointsRedeemed Int      @default(0)
  createdAt      DateTime @default(now())
  customer       customer @relation(fields: [customerId], references: [id], map: "LoyaltyTransaction_customerId_fkey")

  @@index([customerId], map: "LoyaltyTransaction_customerId_fkey")
}

model notification {
  id         Int       @id @default(autoincrement())
  title      String
  message    String
  type       String    @default("SYSTEM")
  isRead     Boolean   @default(false)
  metadata   Json?
  createdAt  DateTime  @default(now())
  customerId String?
  customer   customer? @relation(fields: [customerId], references: [id], map: "Notification_customerId_fkey")

  @@index([customerId], map: "Notification_customerId_fkey")
}

model notificationtemplate {
  id        Int      @id @default(autoincrement())
  body      String   @db.Text
  name      String?  @unique(map: "NotificationTemplate_name_key")
  createdAt DateTime @default(now())
  subject   String?
  type      String?
  updatedAt DateTime
}

model orderitem {
  id            Int          @id @default(autoincrement())
  orderId       Int
  variantId     Int?
  quantity      Int
  unitPrice     Decimal
  name          String?
  image         String?
  description   String?
  customDetails Json?
  itemrating    itemrating?
  orders        orders       @relation(fields: [orderId], references: [id], map: "OrderItem_orderId_fkey")
  cakevariant   cakevariant? @relation(fields: [variantId], references: [id], map: "OrderItem_variantId_fkey")

  @@index([orderId], map: "OrderItem_orderId_fkey")
  @@index([variantId], map: "OrderItem_variantId_fkey")
}

model orders {
  id              Int           @id @default(autoincrement())
  total           Decimal
  loyaltyDiscount Decimal       @default(0.000000000000000000000000000000)
  status          String        @default("NEW")
  orderType       String?
  specialNotes    String?       @db.Text
  paymentStatus   String        @default("PENDING")
  paymentMethod   String        @default("COD")
  advanceAmount   Decimal       @default(0.00) @db.Decimal(10, 2)
  balanceAmount   Decimal       @default(0.00) @db.Decimal(10, 2)
  advanceStatus   String        @default("PENDING")
  bankSlip        String?
  customerId      String
  address         String        @default("")
  deliveryDate    DateTime?
  isEdited        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  bulkorder       bulkorder?
  customorder     customorder?
  delivery        delivery?
  feedback        feedback?
  invoice         invoice?
  orderitem       orderitem[]
  customer        customer      @relation(fields: [customerId], references: [id], map: "Orders_customerId_fkey")
  payment         payment?
  transaction     transaction[]

  @@index([customerId], map: "Orders_customerId_fkey")
}

model payment {
  id            Int           @id @default(autoincrement())
  orderId       Int           @unique(map: "Payment_orderId_key")
  paymentMethod String?
  paymentStatus String?
  proofImage    String?
  verifiedAt    DateTime?
  orders        orders        @relation(fields: [orderId], references: [id], map: "Payment_orderId_fkey")
  transaction   transaction[]
}

model sitesetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique(map: "SiteSetting_key_key")
  value     String?  @db.Text
  group     String?
  updatedAt DateTime
}

model transaction {
  id          Int       @id @default(autoincrement())
  type        String
  category    String?
  amount      Decimal   @db.Decimal(10, 2)
  description String?
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  billUrl     String?
  cashBookId  Int?
  orderId     Int?
  paymentId   Int?
  paymentMode String?   @default("Cash")
  cashbook    cashbook? @relation(fields: [cashBookId], references: [id], map: "Transaction_cashBookId_fkey")
  orders      orders?   @relation(fields: [orderId], references: [id], map: "Transaction_orderId_fkey")
  payment     payment?  @relation(fields: [paymentId], references: [id], map: "Transaction_paymentId_fkey")

  @@index([cashBookId], map: "Transaction_cashBookId_fkey")
  @@index([orderId], map: "Transaction_orderId_fkey")
  @@index([paymentId], map: "Transaction_paymentId_fkey")
}
